# IvLan Environment Configuration Template
# Copy this file to .env and adjust values as needed

# Log level
RUST_LOG=ivland=trace,iroh::socket=warn,tracing=off,iroh::net_report=off,info

# Configuration file path
IV_CONFIG=ivlan.toml

# Interface name for the TUN device
IV_IF_NAME=iv1

# RPC server address
IV_RPC_ADDR=127.0.0.1:2335

# MTU (Maximum Transmission Unit) size
IV_MTU=65475

# IPv4 address for the interface
IV_IP4_ADDR=121.38.0.1

# IPv4 subnet mask (CIDR notation)
IV_IP4_MASK=24

# IPv6 address for the interface
IV_IP6_ADDR=fd00::1

# IPv6 subnet mask (CIDR notation)
IV_IP6_MASK=64

PEER_ID=ccd8bc764b74a680d530bdaf92161f13dd94ccef519c442cd0fb222f60561283